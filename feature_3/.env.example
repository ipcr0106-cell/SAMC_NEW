# cp .env.example .env 후 값 입력 (.env 는 절대 git에 올리지 말 것)

# OpenAI (프론트 AI 라우트 — ai-cross-check, explain-docs, parse-document)
OPENAI_API_KEY=

# Supabase (f3_required_documents, f3_country_groups, f3_keyword_synonyms 조회)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_SERVICE_KEY=

# Voyage (임베딩 — 선택)
VOYAGE_API_KEY=

# Pinecone (법령 청크 RAG 검색 - 85 청크, 인덱스명은 코드 기본값 samc-law-f3 사용)
PINECONE_API_KEY=
