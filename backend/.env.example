# ============================================================
# SAMC 백엔드 환경변수 — 기능별 prefix 규칙
#
# 규칙: 기능 공통이 아닌 키는 F{N}_ prefix를 붙인다.
#       SUPABASE는 전 기능 동일 값이므로 prefix 없음.
#       나머지(OPENAI, PINECONE 등)는 기능별로 다를 수 있으므로 prefix 필수.
# ============================================================

# ── 공통: Supabase (전 기능 동일 값) ──
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# ── F0 (입력 + OCR + 라벨처리) ──
F0_OPENAI_API_KEY=
F0_OPENAI_MODEL=gpt-4o
F0_ANTHROPIC_API_KEY=
F0_PINECONE_API_KEY=
F0_PINECONE_INDEX=samc-law-index
F0_PARSER_SERVICE_URL=http://localhost:3001
F0_PARSER_SERVICE_TOKEN=

# ── F1 (수입 가능 판정) ──
F1_DATABASE_URL=postgresql://postgres:<비밀번호>@db.<ref>.supabase.co:5432/postgres
F1_ANTHROPIC_API_KEY=

# ── F2 (식품유형 분류) ──
F2_OPENAI_API_KEY=
F2_PINECONE_API_KEY=
F2_PINECONE_INDEX=samc-a
# F2_PINECONE_HOST=              # (선택) 인덱스명 대신 host 직접 지정 시

# ── F3 (수입 필요서류 안내) ──
F3_PINECONE_API_KEY=
F3_PINECONE_INDEX_NAME=samc-law-f3
# F3_PINECONE_HOST=              # (선택) 인덱스명 대신 host 직접 지정 시

# ── F4 (수출국 표시사항 검토) ──
F4_OPENAI_API_KEY=
F4_PINECONE_API_KEY=
F4_PINECONE_HOST=                # (필수) 예: https://samc-feature4-laws-xxxxx.pinecone.io
F4_DEEPL_API_KEY=

# ── F5 (한글표시사항 시안) ──
F5_ANTHROPIC_API_KEY=
F5_PINECONE_API_KEY=
F5_PINECONE_INDEX=f5-law-chunks
F5_VOYAGE_API_KEY=
# F5_PINECONE_HOST=              # (선택) 인덱스명 대신 host 직접 지정 시
