# ============================================================
# SAMC 프론트엔드 환경변수
# ============================================================

# ── Supabase (로그인/인증용) ──
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ── Backend API ──
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# ── F3 AI 교차검증/설명 (Next.js API Route에서 사용, 서버사이드) ──
F3_OPENAI_API_KEY=

# ── 아래 키는 프론트에서 직접 사용하지 않음 (백엔드 .env 참고) ──
# F0~F5 API 키는 backend/.env.example 참조
