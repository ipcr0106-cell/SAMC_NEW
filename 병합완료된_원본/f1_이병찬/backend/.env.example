# ============================================================
# SAMC 기능1 환경변수 템플릿
# ============================================================
# 사용:
#   1. 이 파일을 backend/.env 로 복사
#   2. 실제 값 채우기
#   3. 팀컨벤션 §9에 따라 .env 는 절대 커밋 금지 (.gitignore 확인)
# ============================================================

# ── Supabase (필수) ─────────────────────────────────────────
# Dashboard > Settings > API 에서 확보
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
SUPABASE_ANON_KEY=

# Dashboard > Settings > Database > Connection String (URI 형식)
# postgresql://postgres:<PASSWORD>@db.<PROJECT_REF>.supabase.co:5432/postgres
# 직접 Postgres 접속 (asyncpg·마이그레이션용)
DATABASE_URL=

# ── LLM / AI (기능1 ★단계, law_extractor, 기능4·5) ─────────
ANTHROPIC_API_KEY=

# ── Pinecone (기능5 RAG, 선택) ──────────────────────────────
PINECONE_API_KEY=
PINECONE_INDEX=samc-law-index

# ── DeepL (기능4 라벨 번역, 선택) ───────────────────────────
DEEPL_API_KEY=

# ── parser-service (HWP 파싱, 공통 인프라) ──────────────────
PARSER_SERVICE_URL=http://localhost:3001
PARSER_SERVICE_TOKEN=

# ── 이메일 알림 (기능11, 선택) ──────────────────────────────
RESEND_API_KEY=

# ── 서버 설정 ───────────────────────────────────────────────
# FastAPI 포트
PORT=8000
# CORS 허용 origin (쉼표 구분)
CORS_ORIGINS=http://localhost:3000,https://*.vercel.app
